import streamlit as st

# ==================================================
# PAGE
# ==================================================
st.set_page_config(
    page_title="Word Information App",
    page_icon="📘"
)

st.title("📘 Any Word Information Finder")

# ==================================================
# FUNCTION
# ==================================================
def generate_details(word):

    word_upper = word.upper()

    meaning = f"{word} is an important word used in communication and learning."

    full_form = "No Full Form Available"

    if len(word) <= 5:
        full_form = " ".join([letter for letter in word_upper])

    details = f"""
1. {word} is a useful word.
2. This word is commonly used in daily life.
3. The meaning of {word} is related to knowledge and communication.
4. People use {word} in different situations.
5. {word} can be important in education and technology.
6. The word helps in understanding concepts clearly.
7. It is easy to remember and simple to use.
8. {word} may also have different meanings in different fields.
9. This word is valuable for learning and information.
"""

    return meaning, full_form, details

# ==================================================
# INPUT
# ==================================================
word = st.text_input("Enter Any Word")

# ==================================================
# BUTTON
# ==================================================
if st.button("Generate Information"):

    if word:

        meaning, full_form, details = generate_details(word)

        st.subheader("📖 Word Information")

        st.write(f"## 🔤 Word: {word}")

        st.write("## 📘 Meaning")
        st.success(meaning)

        st.write("## 🧾 Full Form")
        st.info(full_form)

        st.write("## 📄 Definition Details")
        st.write(details)

    else:

        st.warning("Please Enter Any Word")
